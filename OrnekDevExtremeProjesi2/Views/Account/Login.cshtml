@using DevExtreme.AspNet.Mvc
@{
    ViewBag.Title = "Giriş Yap";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card-modern p-4">

                <h3 class="mb-4" style="color: var(--accent-blue); font-weight:600;">
                    <i class="dx-icon-user"></i> Giriş Yap
                </h3>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger mb-3">
                        @ViewBag.Error
                    </div>
                }

                @using (Html.BeginForm("Login", "Account", FormMethod.Post))

                {
                    @Html.AntiForgeryToken()
                    @(Html.DevExtreme().Form()
                        .ID("loginForm")
                        .ColCount(1)
                        .LabelLocation(FormLabelLocation.Top)
                        .Items(items =>
                        {
                            items.AddSimple()
                                .Label(l => l.Text("Kullanıcı Adı"))
                                .Template(@<text>
                                    @(Html.DevExtreme().TextBox()
                                        .Name("username")
                                        .ID("loginUserName")
                                        .Placeholder("Kullanıcı adınızı girin")
                                        .ShowClearButton(true)
                                    )
                                </text>);

                            items.AddSimple()
                                .Label(l => l.Text("Şifre"))
                                .Template(@<text>
                                    @(Html.DevExtreme().TextBox()
                                        .Name("password")
                                        .ID("loginPassword")
                                        .Mode(TextBoxMode.Password)
                                        .Placeholder("Şifrenizi girin")
                                        .Buttons(buttons =>
                                        {
                                            buttons.Add()
                                                .Name("password")
                                                .Location(TextEditorButtonLocation.After)
                                                .Widget(w => w.Button()
                                                    .Icon("eyeopen")
                                                    .OnClick("toggleLoginPassword"));
                                        })
                                    )
                                </text>);
                        })
                    )

                    <div class="mt-4">
                        @(Html.DevExtreme().Button()
                            .ID("loginBtn")
                            .Text("Giriş Yap")
                            .Type(ButtonType.Default)
                            .StylingMode(ButtonStylingMode.Contained)
                            .UseSubmitBehavior(true)
                            .Width("100%")
                        )
                    </div>
                }

                <div class="mt-3 text-center">
                    <a href="@Url.Action("Register","Account")">Hesabın yok mu? Kayıt ol</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleLoginPassword() {
        var editor = $("#loginPassword").dxTextBox("instance");
        var currentMode = editor.option("mode");
        editor.option("mode", currentMode === "password" ? "text" : "password");
    }
</script>