@using DevExtreme.AspNet.Mvc
@model OrnekDevExtremeProjesi2.Models.Users


@{
    ViewBag.Title = "Kayıt Ol";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card-modern p-4">

                <h3 class="mb-4" style="color: var(--accent-blue); font-weight:600;">
                    <i class="dx-icon-user"></i> Kayıt Ol
                </h3>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger mb-3">
                        @ViewBag.Error
                    </div>
                }

                @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @(Html.DevExtreme().Form()
                        .ID("registerForm")
                        .ColCount(1)
                        .LabelLocation(FormLabelLocation.Top)
                        .Items(items =>
                        {
                            items.AddSimple()
                                .Label(l => l.Text("Kullanıcı Adı"))
                                .Template(@<text>
                                    @(Html.DevExtreme().TextBox()
                                        .Name("UserName")
                                        .ID("registerUserName")
                                        .Placeholder("Kullanıcı adı girin")
                                        .ShowClearButton(true)
                                    )
                                </text>);

                            items.AddSimple()
                                .Label(l => l.Text("E-Posta"))
                                .Template(@<text>
                                    @(Html.DevExtreme().TextBox()
                                        .Name("Email")
                                        .ID("registerEmail")
                                        .Placeholder("E-posta girin")
                                        .ShowClearButton(true)
                                    )
                                </text>);

                            items.AddSimple()
                                .Label(l => l.Text("Şifre"))
                                .Template(@<text>
                                    @(Html.DevExtreme().TextBox()
                                        .Name("Password")
                                        .ID("registerPassword")
                                        .Mode(TextBoxMode.Password)
                                        .Placeholder("Şifre girin")
                                        .Buttons(buttons =>
                                        {
                                            buttons.Add()
                                                .Name("password")
                                                .Location(TextEditorButtonLocation.After)
                                                .Widget(w => w.Button()
                                                    .Icon("eyeopen")
                                                    .OnClick("toggleRegisterPassword"));
                                        })
                                    )
                                </text>);
                        })
                    )

                    <div class="mt-4">
                        @(Html.DevExtreme().Button()
                            .ID("registerBtn")
                            .Text("Kayıt Ol")
                            .Type(ButtonType.Success)
                            .StylingMode(ButtonStylingMode.Contained)
                            .UseSubmitBehavior(true)
                            .Width("100%")
                        )
                    </div>
                }

                <div class="mt-3 text-center">
                    <a href="@Url.Action("Login","Account")">Zaten hesabın var mı? Giriş yap</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleRegisterPassword() {
        var editor = $("#registerPassword").dxTextBox("instance");
        var currentMode = editor.option("mode");
        editor.option("mode", currentMode === "password" ? "text" : "password");
    }
</script>
