@using OrnekDevExtremeProjesi2.Models.DTOs

@using OrnekDevExtremeProjesi2.Models

@using DevExtreme.AspNet.Mvc
@using System.Web.Helpers



@{

    ViewBag.Title = "Kayıt Yönetimi";

    Layout = "~/Views/Shared/_Layout.cshtml";

}



@* 1. ÖNCE JAVASCRIPT: Grid yüklenmeden önce fonksiyonlar hazır olmalı *@

<script>

    var MainModule = MainModule || { currentNoteMainId: 0 };
    var categoryList = @Html.Raw(Json.Encode(ViewBag.Categories));

    // Sağ tık menüsünü oluşturan ana fonksiyon

    function onMainGridContextMenu(e) {

        if (e.row && e.row.rowType === "data") {

            if (!e.items) e.items = [];

            e.items.push(

                { text: "Detay Git", icon: "info", onItemClick: function () { MainModule.openDetail(e.row.data.Id); } },

                { text: "Düzenle", icon: "edit", onItemClick: function () { e.component.editRow(e.row.rowIndex); } },

                { text: "Notlar", icon: "comment", onItemClick: function () { MainModule.openNotes(e.row.data.Id); } },

                {

                    
                    text: "Sil",
                    icon: "trash",
                    onItemClick: function () {
                        DevExpress.ui.dialog.confirm("Bu kaydı silmek istediğine emin misin?", "Silme Onayı")
                            .done(function (result) {
                                if (result) {
                                    e.component.deleteRow(e.row.rowIndex);
                                }
                            });
                    }
                

                }

            );

        }

    }



    MainModule.openDetail = function (mainId) {
        $("#recordDetailPopup").remove();
        $("<div id='recordDetailPopup'></div>").appendTo("body");

        var popup = $("#recordDetailPopup").dxPopup({
            title: "Kayıt Detay Ekranı - #" + mainId,
            width: 1100,
            height: 700,
            visible: false,
            showCloseButton: true,
            dragEnabled: true,
            hideOnOutsideClick: true,
            contentTemplate: function (container) {
                container.append(
                    "<div id='detailPopupLoader' style='padding:40px; text-align:center;'>Yükleniyor...</div>" +
                    "<div id='detailPopupContent' style='display:none;'></div>"
                );
            },
            onShown: function () {
                if (typeof DetailModule !== "undefined" && DetailModule.init) {
                    DetailModule.init(mainId);
                }
            },
            onHidden: function () {
                $("#recordDetailPopup").remove();
            }
        }).dxPopup("instance");

        popup.show();

        $.get("/Main/Details", { id: mainId }, function (html) {
            $("#detailPopupContent").html(html).show();
            $("#detailPopupLoader").hide();
        });
    };



    MainModule.openNotes = function (mainId) {

        this.currentNoteMainId = mainId;

        if (window.notesPopup) window.notesPopup.show();

        $.get("/Notes/GetByMainId", { id: mainId }, function (data) {

            var html = "";

            data.forEach(function (n) {

                html += `<div style="border-bottom:1px solid #eee; padding:10px;">

                            <b>${n.UserName}</b> <small>${n.CreatedDate}</small>

                            <p>${n.NoteText}</p>

                         </div>`;

            });

            $("#notesList").html(html || "<p>Not bulunamadı.</p>");

        });

    };
    var MainModule = MainModule || { currentNoteMainId: 0 };

    MainModule.openNotes = function (mainId) {
        this.currentNoteMainId = mainId;

        $("#notesPopup").dxPopup("instance").show();

        loadNotes(mainId);
    };

    function loadNotes(mainId) {
        $("#notesGrid").dxDataGrid("instance").option("dataSource", {
            load: function () {
                return $.getJSON("/Notes/GetByMainId", { id: mainId });
            }
        });
    }

    function saveNote() {
        var noteText = $("#noteTextArea").dxTextArea("instance").option("value");
        var mainId = MainModule.currentNoteMainId;

        if (!noteText) {
            DevExpress.ui.notify("Not boş olamaz", "warning", 2000);
            return;
        }

        $.post("/Notes/AddNote", {
            mainId: mainId,
            noteText: noteText
        }, function (res) {
            DevExpress.ui.notify(res.message, res.success ? "success" : "error", 2500);

            if (res.success) {
                $("#noteTextArea").dxTextArea("instance").option("value", "");
                loadNotes(mainId);
                $("#mainGrid").dxDataGrid("instance").refresh();
            }
        });
    }

    function deleteNoteRow(e) {
        var noteId = e.row.data.Id;

        DevExpress.ui.dialog.confirm("Bu notu silmek istiyor musun?", "Onay")
            .done(function (result) {
                if (!result) return;

                $.post("/Notes/DeleteNote", { id: noteId }, function (res) {
                    DevExpress.ui.notify(res.message, res.success ? "success" : "error", 2500);

                    if (res.success) {
                        loadNotes(MainModule.currentNoteMainId);
                        $("#mainGrid").dxDataGrid("instance").refresh();
                    }
                });
            });
    }
    function createStatusBadge(icon, hint, extraClass) {
        return $("<div>")
            .addClass("status-badge " + extraClass)
            .attr("title", hint)
            .append($("<i>").addClass("dx-icon dx-icon-" + icon));
    }

    function statusIconsTemplate(container, options) {
        var data = options.data;

        var wrapper = $("<div>").addClass("status-icons-wrapper");

        if (data.NoteCount > 0) {
            wrapper.append(createStatusBadge("comment", "Not var", "status-note"));
        }

        if (data.DeleteStatus && data.DeleteStatus.indexOf("Bekliyor") !== -1) {
            wrapper.append(createStatusBadge("clock", "Silme onayı bekliyor", "status-waiting"));
        }

        if (data.DeleteStatus === "Reddedildi") {
            wrapper.append(createStatusBadge("close", "Silme reddedildi", "status-rejected"));
        }

        $(container).append(wrapper);
    }
    $(function () {
        checkRejectedNotifications();
    });

    $(function () {
        checkRejectedNotifications();
    });

    function checkRejectedNotifications() {
        $.get("/Main/GetRejectedNotifications", function (res) {
            if (!res || !res.success || !res.data || res.data.length === 0) return;

            res.data.forEach(function (item) {
                var key = "rejected_notification_seen_" + item.Id + "_" + item.LastApprovalDate;

                if (localStorage.getItem(key)) return;

                localStorage.setItem(key, "1");

                var msg = "'" + item.Title + "' silme talebi reddedildi";
                if (item.AdminNote) {
                    msg += " | Not: " + item.AdminNote;
                }

                DevExpress.ui.notify(msg, "error", 5000);
            });
        });
    }







</script>



<style>
    .status-icons-wrapper {
        display: flex;
        align-items: center;
        justify-content: center; /* 🔥 ORTALAR */
        gap: 8px;
        height: 100%;
    }

    .status-badge {
        width: 30px;
        height: 30px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

        .status-badge i {
            font-size: 16px;
        }

    /* 💬 NOT */
    .status-note {
        background: #eef2ff;
        color: #4f46e5;
    }

    /* ⏳ BEKLEME */
    .status-waiting {
        background: #fff7ed;
        color: #ea580c;
    }

    /* ❌ RED */
    .status-rejected {
        background: #fef2f2;
        color: #dc2626;
    }

    /* hover efekti */
    .status-badge:hover {
        transform: scale(1.08);
    }
    .badge {
        text-decoration: none !important;
        border-bottom: none !important;
        display: inline-block;
        padding: 0.4em 0.6em;
    }

    
    .notesGridDeleteBtn {
        background: #dc3545 !important;
        color: #fff !important;
        border: 1px solid #dc3545 !important;
        border-radius: 6px !important;
        padding: 6px 12px !important;
        text-decoration: none !important;
        display: inline-block !important;
        font-weight: 500;
    }

    .notesGridDeleteBtn:hover {
        background: #bb2d3b !important;
        color: #fff !important;
        text-decoration: none !important;
    }
</style>



<div class="container-fluid mt-4">

    <div class="card-modern p-4">

        <h3 class="mb-3" style="color: var(--accent-blue); font-weight: 600;">

            <i class="dx-icon-home"></i> Kayıt Yönetim Paneli

        </h3>

        @(Html.DevExtreme().Popup()
    .ID("notesPopup")
    .Title("Notlar")
    .Width(900)
    .Height(650)
    .Visible(false)
    .ShowCloseButton(true)
    .DragEnabled(true)
    .ContentTemplate(@<text>

        <div style="margin-bottom:15px;">
            @(Html.DevExtreme().TextArea()
                .ID("noteTextArea")
                .Height(100)
                .Placeholder("Notunuzu yazın...")
            )
        </div>

        <div style="margin-bottom:15px;">
            @(Html.DevExtreme().Button()
                .Text("Not Ekle")
                .Type(ButtonType.Success)
                .StylingMode(ButtonStylingMode.Contained)
                .OnClick("saveNote")
            )
        </div>

        @(Html.DevExtreme().DataGrid<NoteListDto>()
            .ID("notesGrid")
            .ShowBorders(true)
            .RowAlternationEnabled(true)
            .ColumnAutoWidth(true)
            .Height(350)
            .Paging(p => p.PageSize(8))
            .Pager(p =>
            {
                p.Visible(true);
                p.ShowInfo(true);
            })
            .Columns(columns =>
            {
                columns.AddFor(m => m.UserName)
                    .Caption("Kullanıcı")
                    .Width(140);

                columns.AddFor(m => m.NoteText)
                    .Caption("Not");

                columns.AddFor(m => m.CreatedDate)
                    .Caption("Tarih")
                    .Width(150);

                columns.Add()
     .Type(GridCommandColumnType.Buttons)
     .Caption("İşlem")
     .Width(100)
     .Buttons(buttons =>
     {
         buttons.Add()
             .Text("Sil")
             .Hint("Sil")
             .CssClass("notesGridDeleteBtn")
             .OnClick("deleteNoteRow");
     });
            })
        )

    </text>)
)
        @(Html.DevExtreme().DataGrid<MainListDto>()

            .ID("mainGrid")

            .DataSource(d => d.Mvc()

                .Controller("Main")

                .LoadAction("GetMainList")

                .InsertAction("CreateMain")

                .UpdateAction("UpdateMain")

                .DeleteAction("DeleteMain")

                .Key("Id")

            )

            .ShowBorders(true)
            .SearchPanel(sp => sp.Visible(true).Width(240).Placeholder("Ara..."))
.FilterRow(fr => fr.Visible(true))

            .Columns(columns => {
                columns.Add()
    .Caption("Durum")
    .Width(110)
    .Alignment(HorizontalAlignment.Center) // 🔥 BUNU EKLE
    .CellTemplate(new JS("statusIconsTemplate"));

                columns.AddFor(m => m.Id).Width(80).Caption("ID").Visible(true);



                columns.AddFor(m => m.CategoryId).Caption("Kategori")
    .Lookup(lookup => lookup
        .DataSource(new JS("categoryList"))
        .DisplayExpr("Name")
        .ValueExpr("Id")
    );



                columns.AddFor(m => m.Title).Caption("Başlık");

                columns.AddFor(m => m.Description).Caption("Açıklama");

                columns.AddFor(m => m.IsActive).Caption("Durum").Width(100)

                    .CellTemplate(@<text>

                        <span class="badge <%= value ? "badge-success" : "badge-danger" %>"

                              style="color: <%= value ? "#28a745" : "#dc3545" %>; font-weight: bold;">

                            <%= value ? "Aktif" : "Pasif" %>

                        </span>

                    </text>);



                columns.Add().Type(GridCommandColumnType.Buttons).Visible(false);

            })



            .Editing(e => e.Mode(GridEditMode.Popup)

                .AllowUpdating(true)

                .AllowAdding(true)
                .AllowDeleting(true)
    .ConfirmDelete(false)


                .Popup(p => p.Title("Kayıt Formu").Width(500).Height(450))



               .Form(f => f.Items(items =>

               {

                   items.AddSimpleFor(m => m.Title);



                   items.AddSimpleFor(m => m.CategoryId)
     .Label(l => l.Text("Kategori"));

                   items.AddSimpleFor(m => m.Description)

                       .Editor(ed => ed.TextArea().Height(80));



                   items.AddSimpleFor(m => m.IsActive)

                       .Editor(ed => ed.Switch());

               }))

            )

            .OnContextMenuPreparing("onMainGridContextMenu")

        )

    </div>

</div>