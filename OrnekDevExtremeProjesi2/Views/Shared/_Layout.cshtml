@using OrnekDevExtremeProjesi2.Models.DTOs

@using OrnekDevExtremeProjesi2.Models

@using DevExtreme.AspNet.Mvc
@using System.Web.Helpers
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>OrnekDevExtremeProjesi2</title>
    <link href="~/favicon.ico" rel="shortcut icon" type="image/x-icon" />

    @Styles.Render("~/Content/bundle")
    @Styles.Render("~/Content/DevExtremeBundle")
    @Scripts.Render("~/Scripts/bundle")
    @Scripts.Render("~/Scripts/DevExtremeBundle")

    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            background: #f5f7fb;
            overflow: hidden;
        }

        .layout-shell {
            height: 100vh;
        }

        .layout-menu {
            height: 100%;
            background: #172133;
            color: #fff;
            padding-top: 12px;
        }

        .layout-brand {
            font-size: 22px;
            font-weight: 700;
            padding: 16px 20px 24px 20px;
            color: #fff;
        }

        .layout-content {
            padding: 24px;
            height: 100vh;
            overflow: auto;
        }

        .dx-treeview-node {
            color: #fff;
        }

        .dx-treeview-toggle-item-visibility {
            color: #fff;
        }
    </style>
</head>
<body>
    

    @(Html.DevExtreme().Drawer()
        .ID("appDrawer")
        .Opened(true)
        .OpenedStateMode(DrawerOpenedStateMode.Shrink)
        .RevealMode(DrawerRevealMode.Expand)
        .MinSize(220)
        .MaxSize(220)
        .Shading(false)
        .ElementAttr("class", "layout-shell")
        .Template(@<text>
            <div class="layout-menu">
                <div class="layout-brand">Mini Kayıt Sistemi</div>

                @(Html.DevExtreme().TreeView()
    .ID("sideMenuTree")
    .Items(items =>
    {



        if (Session["UserId"] != null)
        {
            items.Add()
                .Text("Ana Sayfa")
                .Icon("home")
                .Option("url", Url.Action("Index", "Main"));

            if ((Session["Role"] != null ? Session["Role"].ToString() : "") == "Admin")
            {
                items.Add()
                    .Text("Onay Talepleri")
                    .Icon("todo")
                    .Option("url", Url.Action("Approvals", "Approval"));
                items.Add()
    .Text("Sistem Logları")
    .Icon("event")
    .Option("url", Url.Action("Index", "Logs"));
            }

            items.Add()
                .Text("Profil")
                .Icon("user")
                .Option("url", Url.Action("Profile", "Profile"));

            items.Add()
                .Text("Çıkış Yap")
                .Icon("runner")
                .Option("url", Url.Action("Logout", "Account"));
        }
        else
        {
            items.Add()
                .Text("Giriş Yap")
                .Icon("login")
                .Option("url", Url.Action("Login", "Account"));

            items.Add()
                .Text("Kayıt Ol")
                .Icon("plus")
                .Option("url", Url.Action("Register", "Account"));
        }
    })
    .SelectionMode(NavSelectionMode.Single)
    .FocusStateEnabled(false)
    .ExpandEvent(TreeViewExpandEvent.Click)
    .OnItemClick("onSideMenuItemClick")
)
            </div>
        </text>)
        .Content(@<text>
            <div class="layout-content">
                @RenderBody()
            </div>
        </text>)
    )

    <script>

        function onSideMenuItemClick(e) {
            var url = e.itemData.url;
            if (url) {
                window.location.href = url;
            }
        }

    </script>

    @RenderSection("scripts", required: false)
</body>
</html>